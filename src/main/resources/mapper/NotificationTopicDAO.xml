<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ru.delmark.dads.notifications.data.repository.NotificationTopicDAO">

    <resultMap id="notificationTopic" type="ru.delmark.dads.notifications.data.model.NotificationTopic">
        <id property="id" column="topic_id"/>
        <result property="name" column="name"/>
        <result property="alias" column="alias"/>
        <result property="description" column="description"/>
        <result property="displayPriority" column="display_priority"/>
        <result property="minAccessLevel" column="min_access_level"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="baseSelect">
        t.topic_id,
        t.name,
        t.readable_alias as alias,
        t.description,
        t.display_priority,
        am.name as min_access_level,
        t.created_at
    </sql>

    <sql id="baseFrom">
        FROM notification_topic t
        JOIN access_mode am on t.min_access_level = am.access_level
    </sql>

    <select id="getNotificationTopics" resultMap="notificationTopic">
        SELECT
        <include refid="baseSelect"/>
        <include refid="baseFrom"/>
        <where>
            <if test="filter.getTopicIds() != null and !filter.getTopicIds().isEmpty()">
                t.topic_id = ANY(
                    <foreach collection="filter.getTopicIds()" item="id" separator="," open="ARRAY[" close="]">
                        #{id}
                    </foreach>::int[]
                )
            </if>
        </where>
    </select>

    <select id="getNotificationTopic" resultMap="notificationTopic">
        SELECT
        <include refid="baseSelect"/>
        <include refid="baseFrom"/>
        WHERE t.name = #{topicKey} or t.readable_alias = #{topicKey}
    </select>

</mapper>